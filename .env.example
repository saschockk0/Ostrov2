# ── База данных (Turso) ───────────────────────────────────────────────────────
# turso.tech: turso db create ostrov && turso db show ostrov --url
TURSO_URL=libsql://your-db-name.turso.io
# turso db tokens create ostrov
TURSO_AUTH_TOKEN=your-token-here

# Для локальной разработки — можно оставить пустыми (используется file:data/ostrov.db)

# ── Загрузка файлов (Vercel Blob) ─────────────────────────────────────────────
# Vercel Dashboard: Storage → Blob → Create Store → скопировать токен
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@yandex.ru
SMTP_PASS=your-app-password
MANAGER_EMAIL=manager@ostrov-sailing.ru

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ── Админка ───────────────────────────────────────────────────────────────────
ADMIN_LOGIN=admin
ADMIN_PASSWORD=strong-password-here
ADMIN_SESSION_SECRET=random-secret-string

# ── Яндекс отзывы ─────────────────────────────────────────────────────────────
YANDEX_OAUTH_TOKEN=y0_AgAAAA...
YANDEX_ORG_ID=12345678
