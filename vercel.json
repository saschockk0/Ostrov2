{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/ostrov-admin/:path*", "destination": "/api/index" },
    { "source": "/ostrov-admin", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
